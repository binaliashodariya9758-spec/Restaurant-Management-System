#include<iostream>
using namespace std;

class Food
{
protected:
    int price;

public:
    virtual void setPrice() = 0;
    int getPrice()
    {
        return price;
    }
};

class Pizza : public Food
{
public:
    void setPrice()
    {
        price = 200;
    }
};

class Burger : public Food
{
public:
    void setPrice()
    {
        price = 100;
    }
};

class Pasta : public Food
{
public:
    void setPrice()
    {
        price = 150;
    }
};

class Sandwich : public Food
{
public:
    void setPrice()
    {
        price = 120;
    }
};

class Bill
{
private:
    int total;

public:
    Bill()
    {
        total = 0;
    }

    void addItem(Food *f, int qty)
    {
        total += f->getPrice() * qty;
    }

    void showTotal()
    {
        cout << "Total Bill : " << total;
    }
};

int main()
{
    int choice = 0, qty;
    Bill b;

    while(choice != 5)
    {
        cout<<"\n Menu\n";
        cout<<"1.Pizza - 200\n2.Burger - 100\n3.Pasta - 150\n4.Sandwich - 120\n5.Exit\n";
        cout<<"Enter your Choice: ";
        cin>>choice;

        Food *f;

        if(choice == 1)
            f = new Pizza();
        else if(choice == 2)
            f = new Burger();
        else if(choice == 3)
            f = new Pasta();
        else if(choice == 4)
            f = new Sandwich();
        else if(choice == 5)
            break;
        else
        {
            cout<<"Invalid Choice\n";
            continue;
        }

        f->setPrice();

        cout<<"Enter quantity: ";
        cin>>qty;

        b.addItem(f, qty);
    }

    b.showTotal();

    return 0;
}
